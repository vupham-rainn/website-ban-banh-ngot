trang chủ","toggleTheme":"Chuyển đổi giao diện","toolList":{"aiFigmaPlugin":"Plugin AI Figma","aiImageGenerator":"Trình tạo hình ảnh AI","aiSolutions":"Các giải pháp hỗ trợ AI của chúng tôi","aiTools":"Công cụ AI","explore":"Khám phá hình ảnh AI","subtitle":"Vượt qua giới hạn trí tưởng tượng của bạn với những hình ảnh chất lượng cao được tạo ra bởi Trí tuệ nhân tạo.","title":"Hàng ngàn hình ảnh được hỗ trợ bởi AI"},"tools":"Bộ Sản Phẩm AI","toolsCategories":"Thủ công và chỉnh sửa","upgrade":"Nâng cấp","upgradeToGetMore":"Nâng cấp để nhận thêm nhiều quyền lợi","upscale":"Phóng to","upscaleVideo":"Tăng cường video","useAICode":{"applyButton":"Sử dụng Mã","genericError":"Mã không hoạt động? Hãy thử lại hoặc liên hệ với bộ phận hỗ trợ","inputLabel":"Mã mời ở đây","inputPlaceholder":"ví dụ AICODE123","successMessage":"Mã đã được áp dụng thành công","title":"Sử dụng Mã AI của bạn và bắt đầu sáng tạo với AI"},"userMenu":{"account":"Tài khoản","admin":"Quản trị viên","cancelled":"Đã hủy","creatorProfile":"Hồ sơ người sáng tạo","credits":"Sử dụng bản quyền","dark":"Tối","devices":"Thiết bị","discord":"Tham gia máy chủ Discord","downloads":"Tải xuống","enterprise":"Enterprise","faq":"$t(nav:faq)","favorites":"Yêu thích","following":"$t(common:following)","frozen":"Đã tạm dừng","helpCenter":"Trung tâm trợ giúp","joinCommunity":"Tham gia cộng đồng","language":"Ngôn ngữ","light":"Ánh sáng","limit":"Giới hạn","logOut":"Đăng xuất","member":"Thành viên","myCollections":"Bộ sưu tập của tôi","owner":"Chủ sở hữu","profile":"Hồ sơ","projects":"Dự án Thiết kế","spent":"Đã dùng","subscription":"Đăng ký","system":"Hệ thống","team":"Đội","theme":"Chủ đề","unpaid":"Thanh toán không thành công","useAICode":"Sử dụng mã AI","user":"Tài khoản","whatIsThis":"Đây là cái gì?"},"vectors":"Vector","vectorsAll":"Khám phá tất cả các vectơ","vectorsCategories":"Các loại vectơ","vectorsCollections":"Bộ sưu tập vector","vectorsHome":"Trang chủ Vector","videoCategories":"Thể loại video","videoTemplates":"Mẫu video","videos":"Video","videosAll":"Khám phá tất cả video","videosCategories":"Thể loại video","videosHome":"Video trang chủ","viewDetails":"Xem chi tiết","voiceOver":"Thuyết minh","workspace":"Không gian làm việc"},"templatesCategoryBannerMaker":{"FAQ":"Câu hỏi thường gặp","americanFlagBanners":"Mẫu biểu ngữ cờ Mỹ","animeBanners":"Mẫu banner anime","bakeryBanners":"Mẫu biểu ngữ tiệm bánh","beerBanners":"Mẫu biểu ngữ bia","birthdayBanners":"Mẫu banner sinh nhật","blackFridayBanners":"Mẫu biểu ngữ Black Friday","blackHistoryMonthBanners":"Mẫu biểu ngữ Tháng Lịch sử Người da đen","breadcrumbTitle":"Nhà sản xuất biểu ngữ","breakingNewsBanners":"Mẫu biểu ngữ tin tức mới nhất","carnivalBanners":"Mẫu biểu ngữ lễ hội","catBanners":"Mẫu biểu ngữ mèo","categoryRow1":"Trình tạo logo","categoryRow2":"Trình tạo poster","categoryRow3":"Trình tạo tờ rơi","categoryRow4":"Trình tạo danh thiếp","categoryRow5":"Trình tạo sơ yếu lý lịch","categoryRow6":"Trình tạo banner","cateringBanners":"Mẫu biểu ngữ phục vụ ăn uống","colorfulBanners":"Mẫu biểu ngữ đầy màu sắc","coverSubtitle":"Tạo các banner thu hút và đưa thương hiệu của bạn lên hàng đầu","coverTitle":"Trình tạo banner trực tuyến miễn phí","createFromScratch":"Tự tạo từ đầu","cyberMondayBanners":"Mẫu biểu ngữ Cyber Monday","dentalBanners":"Mẫu biểu ngữ nha khoa","discordBanners":"Mẫu biểu ngữ Discord","discountBanners":"Mẫu biểu ngữ giảm giá","easterBanners":"Mẫu biểu ngữ lễ Phục sinh","emailBanners":"Mẫu biểu ngữ email","facebookBanners":"Mẫu biểu ngữ Facebook","fallBanners":"Mẫu biểu ngữ mùa thu","faqsCategory1Content1":"Biểu ngữ là một phần nội dung trực quan, thường là sự kết hợp giữa văn bản và hình ảnh, được thiết kế để thu hút sự chú ý và truyền tải thông điệp. Biểu ngữ thường được sử dụng trong quảng cáo, khuyến mại và thiết kế web để làm nổi bật thông tin hoặc khuyến khích người xem hành động. Để sử dụng hiệu quả, hãy đặt biểu ngữ ở phía trước nơi đối tượng mục tiêu của bạn có thể dễ dàng nhìn thấy.","faqsCategory1Content2":"Kích thước banner sẽ khác nhau tùy thuộc vào nơi bạn định sử dụng. Banner kỹ thuật số thường có các kích thước tiêu chuẩn như 728×90 pixel (leaderboard) hoặc 300×250 pixel (hình chữ nhật trung bình). Đối với banner in ấn, kích thước phổ biến là khoảng 4×8 feet (1,2m×2,4m). Kích thước banner tốt nhất sẽ phụ thuộc vào không gian hiển thị và mức độ hiển thị bạn cần.\n\u003c7\u003e\u003c3\u003e\u003c2\u003e\u003c5\u003eKích thước banner YouTube:\u003c/5\u003e\u003c/2\u003e Kích thước tối đa cho việc tải lên là 2560×1440 pixel với tỷ lệ khung hình 16:9.\u003c/3\u003e\n\u003c3\u003e\u003c2\u003eKích thước banner Twitter:\u003c/2\u003e Kích thước được đề xuất cho Twitter là 1500×500 pixel. Điều này đảm bảo hình ảnh của bạn sắc nét trên mọi thiết bị.\u003c/3\u003e\n\u003c3\u003e\u003c2\u003eKích thước banner LinkedIn:\u003c/2\u003e Banner trên LinkedIn nên có kích thước 1584×396 pixel để hiển thị đúng trong phần tiêu đề hồ sơ.\u003c/3\u003e\n\u003c3\u003e\u003c2\u003eKích thước banner Twitch:\u003c/2\u003e Twitch khuyến nghị sử dụng banner kích thước 1920×480 pixel cho phần tiêu đề hồ sơ, giúp kênh của bạn trông chuyên nghiệp hơn.\u003c/3\u003e\n\u003c3\u003e\u003c2\u003eKích thước banner Discord:\u003c/2\u003e Kích thước lý tưởng cho banner Discord là 1920×480 pixel, phù hợp cho hồ sơ và máy chủ.\u003c/3\u003e\u003c/7\u003e","faqsCategory1Content3":"Biểu ngữ phải hiển thị rõ ràng tiêu đề để thu hút sự chú ý, hình ảnh hoặc đồ họa hấp dẫn để thu hút người xem và lời kêu gọi hành động ngắn gọn hướng dẫn khán giả những việc cần làm tiếp theo.","faqsCategory1Content4":"Chắc chắn rồi. Duyệt qua tất cả các biểu ngữ logo của chúng tôi bằng cách nhấp vào \"Xem tất cả biểu ngữ\" và phù hợp nhất với bạn. Sau đó, tùy chỉnh theo ý thích của bạn trong trình chỉnh sửa trực tuyến, từ màu sắc đến văn bản, rồi tải xuống kết quả cuối cùng theo định dạng bạn muốn.","faqsCategory1Content5":"Khi thiết kế của bạn đã sẵn sàng, hãy nhấn nút Tải xuống nằm ở góc trên bên phải của trình chỉnh sửa, chọn định dạng PNG, JPEG hoặc PDF và đợi vài phút cho đến khi quá trình tải xuống hoàn tất.","faqsCategory1Title1":"Banner là gì và cách sử dụng?","faqsCategory1Title2":"Banner có kích thước bao nhiêu?","faqsCategory1Title3":"Một banner nên bao gồm những thông tin chính nào?","faqsCategory1Title4":"Tôi có thể sử dụng mẫu có sẵn không?","faqsCategory1Title5":"Làm thế nào để tải xuống thiết kế cuối cùng của tôi?","fashionBanners":"Mẫu banner thời trang","flagBanners":"Mẫu biểu ngữ cờ","floralBanners":"Mẫu biểu ngữ hoa","galaxyBanners":"Mẫu biểu ngữ thiên hà","gamingBanners":"Mẫu biểu ngữ trò chơi","graduationBanners":"Mẫu biểu ngữ tốt nghiệp","greenBanners":"Mẫu biểu ngữ màu xanh lá cây","gymBanners":"Mẫu biểu ngữ phòng tập thể dục","headingSectionName":"Trình tạo banner","headingSubtitle":"Làm nổi bật thương hiệu và thu hút sự chú ý bằng cách tạo banner cho mọi dịp, hoàn toàn miễn phí. Tùy chỉnh bất kỳ mẫu nào của chúng tôi hoặc bắt đầu từ đầu ngay bây giờ.","headingTitle":"Trình tạo banner dễ sử dụng cho mọi người","horizontalBanners":"Mẫu biểu ngữ ngang","leaderboardBanners":"Mẫu biểu ngữ bảng xếp hạng","linkedinBanners":"Mẫu biểu ngữ LinkedIn","makersToGoSectionName":"Nhiều công cụ hơn để sử dụng","makersToGoSubtitle":"Nâng tầm kỹ năng thiết kế của bạn với các công cụ trực tuyến của chúng tôi. Chúng tôi có mọi thứ bạn cần để tạo ra các hình ảnh trực quan tuyệt đẹp cho bất kỳ dự án nào bạn đang nghĩ đến. Cho dù bạn là một chuyên gia dày dặn hay là người mới bước chân vào thế giới thiết kế, bạn sẽ yêu thích các tùy chọn tùy chỉnh của chúng tôi","makersToGoTitle":"Các Designer hàng đầu cho sự sáng tạo vô tận","mediumRectangleBanners":"Mẫu biểu ngữ hình chữ nhật trung bình","newYearBanners":"Mẫu biểu ngữ năm mới","ogDescription":"Thiết kế thông điệp của bạn bằng hình ảnh. Trình tạo banner miễn phí của chúng tôi cho phép bạn tạo ra những thiết kế bắt mắt, thu hút sự chú ý và mang lại hiệu quả. Tạo banner trong vài phút, miễn phí!","ogTitle":"Freepik | Trình tạo Banner miễn phí - Tạo Banner tùy chỉnh trực tuyến","oktoberfestBanners":"Mẫu biểu ngữ Oktoberfest","orangeBanners":"Mẫu biểu ngữ màu cam","pinkBanners":"Mẫu biểu ngữ màu hồng","prideBanners":"Mẫu biểu ngữ tự hào","purpleBanners":"Mẫu biểu ngữ màu tím","rainbowBanners":"Mẫu biểu ngữ cầu vồng","realEstateBanners":"Mẫu banner bất động sản","refractableBanners":"Mẫu biểu ngữ có thể bẻ cong","relatedArticlesTitle":"Tìm hiểu thêm về banner","restaurantBanners":"Mẫu banner nhà hàng","saleBanners":"Mẫu biểu ngữ bán hàng","seeAll":"Xem các mẫu banner","seoDescription":"Thiết kế thông điệp của bạn, một cách trực quan. Trình tạo banner miễn phí của chúng tôi cho phép bạn tạo ra các thiết kế bắt mắt thu hút sự chú ý và mang lại hiệu quả. Tạo banner chỉ trong vài phút, hoàn toàn miễn phí!","seoTitle":"Trình tạo Banner miễn phí - Tạo Banner tùy chỉnh trực tuyến | Freepik","simpleBanners":"Mẫu biểu ngữ đơn giản","sportsBanners":"Biểu ngữ thể thao","squareBanners":"Mẫu biểu ngữ hình vuông","summerBanners":"Mẫu biểu ngữ mùa hè","tabBusiness":"Việc kinh doanh","tabEvents":"Sự kiện","tabSocialMedia":"Phương tiện truyền thông xã hội","tabStyle":"Phong cách","tabTopic":"Đề tài","thanksgivingBanners":"Mẫu biểu ngữ Lễ Tạ ơn","tumblrBanners":"Mẫu biểu ngữ Tumblr","twitchBanners":"Mẫu biểu ngữ Twitch","twitterBanners":"Mẫu biểu ngữ Twitter","useCase1Content":"Bạn đang gặp khó khăn trong việc tạo banner bắt mắt cho thương hiệu hoặc sự kiện của mình? Nếu vậy, hãy tạm biệt sự thất vọng và chào đón Trình Tạo Banner.\u003c1 /\u003e\u003c1 /\u003e\n\nGiải phóng khả năng sáng tạo của bạn và cá nhân hóa thiết kế bằng thông điệp của bạn, thêm hình ảnh trực quan sống động và điều chỉnh màu sắc cho phù hợp với thương hiệu hoặc chủ đề của bạn. Sau khi hoàn tất, bạn chỉ cần tải xuống kiệt tác của mình ở định dạng \u003c2\u003ePNG, JPEG hoặc PDF\u003c/2\u003e và bắt đầu thu hút khán giả.","useCase1LinkLabel":"Tự tạo từ đầu","useCase1Title":"Trình tạo banner, trợ thủ đắc lực của bạn","useCase2Content":"Banner là một công cụ giao tiếp trực quan và hiệu quả cao, có thể thu hút sự chú ý và truyền tải thông điệp. Chúng thường được sử dụng và đặt ở những vị trí chiến lược cho mục đích quảng cáo, marketing, kỷ niệm và thông báo đặc biệt.\u003c1 /\u003e\u003c1 /\u003e\n\nChúng cực kỳ linh hoạt và có nhiều kích cỡ, thiết kế và vị trí khác nhau, biến chúng trở nên lý tưởng cho cả không gian vật lý và kỹ thuật số. Banner không chỉ mang tính trang trí; chúng được thiết kế để khơi gợi suy nghĩ, tạo sự quan tâm và truyền cảm hứng cho người xem hành động.","useCase2LinkLabel":"Duyệt các mẫu banner","useCase2Title":"Mục đích của một banner là gì?","useCase3Content":"Bước vào thế giới của những thiết kế banner đang chờ đợi khơi dậy khả năng sáng tạo của bạn. Cho dù là cho các kênh truyền thông xã hội hay trang web của bạn, bạn sẽ tìm thấy một mẫu phù hợp.\u003c1 /\u003e\u003c1 /\u003e\n\nVới sự trợ giúp của trình chỉnh sửa trực tuyến trực quan, hãy tải lên logo thương hiệu của bạn, sửa đổi bất kỳ màu sắc nào cũng như kéo và thả các yếu tố một cách dễ dàng. Banner mơ ước của bạn chỉ cách bạn vài cú nhấp chuột!","useCase3Title":"Khám phá các mẫu banner và tìm kiếm cảm hứng","useCase4Content":"\u003c2\u003e1. Tiêu đề chính:\u003c/2\u003e Đây là yếu tố thu hút sự chú ý của bạn, là đoạn văn bản lớn, in đậm, thu hút ánh nhìn đầu tiên.\u003c1 /\u003e\n\u003c2\u003e2. Hình ảnh trực quan:\u003c/2\u003e Hình ảnh hoặc đồ họa bổ trợ cho văn bản của bạn và làm cho banner trở nên hấp dẫn.\u003c1 /\u003e\n\u003c2\u003e3. Kêu gọi hành động:\u003c/2\u003e Một lời thúc giục người xem, cho họ biết bạn muốn họ làm gì tiếp theo.\u003c1 /\u003e\n\u003c2\u003e4. Xây dựng thương hiệu:\u003c/2\u003e Thường là logo hoặc khẩu hiệu, một thứ gì đó xác định banner với thương hiệu hoặc tổ chức của bạn.","useCase4Title":"Lưu ý đến cấu trúc banner","useCase5Content":"\u003c2\u003eĐơn giản hóa thông điệp của bạn:\u003c/2\u003e Hãy nghĩ về điều chính yếu bạn muốn mọi người nhớ hoặc làm sau khi thấy banner của bạn. Tập trung vào điều đó và loại bỏ phần còn lại.\u003c1 /\u003e\n\u003c2\u003eChọn màu sắc một cách khôn ngoan:\u003c/2\u003e Đảm bảo văn bản của bạn nổi bật trên nền. Độ tương phản là yếu tố quan trọng để dễ đọc, ngay cả từ xa.\u003c1 /\u003e\n\u003c2\u003eChọn hình ảnh có độ phân giải cao:\u003c/2\u003e Nếu bạn đang sử dụng ảnh hoặc logo, hãy đảm bảo ảnh có độ phân giải cao, vì ảnh bị mờ hoặc vỡ hình có thể làm hỏng giao diện cuối cùng.\u003c1 /\u003e\n\u003c2\u003eLuôn là chính bạn:\u003c/2\u003e Đảm bảo banner của bạn mang lại cảm giác là một phần của thương hiệu. Bạn có thể đạt được điều này bằng cách tuân thủ bảng màu và kiểu phông chữ của thương hiệu.","useCase5Title":"Khám phá thêm các mẹo thiết kế banner","useCases2SectionName":"Đây là cách bạn thực hiện","useCases2Subtitle":"Khám phá cách thiết kế một banner hấp dẫn cho mạng xã hội hoặc trang web của bạn, hoàn toàn theo ý bạn. Thật nhanh chóng và dễ dàng, ngay cả khi bạn chưa từng thiết kế bất cứ thứ gì trước đây.","useCases2Title":"Tạo banner siêu tốc","websiteBanners":"Mẫu banner trang web","wideSkyscraperBanners":"Mẫu biểu ngữ nhà chọc trời rộng","winterBanners":"Mẫu biểu ngữ mùa đông","yellowBanners":"Mẫu biểu ngữ màu vàng","youtubeBanners":"Mẫu biểu ngữ YouTube"},"collections":{"backToCollections":"Quay lại bộ sưu tập","backToMyCollections":"Quay lại bộ sưu tập của tôi","browseAssets":"Duyệt tài sản","browseFreepik":"Duyệt Freepik và bắt đầu thêm tài sản vào bộ sưu tập của bạn","changesSavedSuccessfully":"Đã lưu thay đổi thành công","collectionCreatedSuccessfully":"Bộ sưu tập đã được tạo thành công","collectionDescription":"Mô tả bộ sưu tập","collectionFollowed":"Bộ sưu tập đã được thêm vào bộ sưu tập của bạn","collectionNeedTitle":"Bạn cần đặt tên cho bộ sưu tập của mình","collectionsCuratedTitle":"Đồ họa cao cấp tốt nhất trên Freepik","collectionsTitle":"Tải xuống miễn phí các vector, ảnh và PSD | Freepik","createCollection":"Tạo bộ sưu tập","delete":"Xóa bỏ","deleteAdvise":"Thao tác này sẽ xóa vĩnh viễn tất cả các tài sản trong bộ sưu tập này, nhưng bất kỳ mục nào được thích vẫn sẽ có trong mục Yêu thích","deleteCollection":"Xóa bộ sưu tập","deleteCollectionQuestion":"Xóa bộ sưu tập?","deleteConfirmation":"Có, xóa","descriptionCollection":"Mô tả bộ sưu tập","descriptionOptional":"Mô tả (tùy chọn)","edit":"Biên tập","editCollection":"Chỉnh sửa bộ sưu tập","exploreTrendyCollections":"Khám phá bộ sưu tập hợp thời trang nhất của Freepik và tìm hình ảnh hoàn hảo.","followers":"Người theo dõi","nameCollection":"Bộ sưu tập tên","newCollection":"Bộ sưu tập mới","noCollections":"Chưa có bộ sưu tập nào để hiển thị!\n Tìm ở đây bất kỳ bộ sưu tập được tuyển chọn nào mà bạn lưu","noCollectionsAvailable":"Không có bộ sưu tập nào có sẵn","pinterestEmptyCollectionError":"Thêm nội dung vào bộ sưu tập của bạn trước khi chia sẻ","privateCollectionDescription":"Chủ sở hữu đã biến bộ sưu tập này thành riêng tư nhưng bạn vẫn có thể khám phá Freepik và khám phá hình ảnh, tâm trạng và phong cách để khơi dậy sự sáng tạo của bạn","privateCollectionTitle":"Ồ, bộ sưu tập này không còn công khai nữa","publicOption":"\u003c1\u003e Công khai. \u003c/1\u003e Mở cho tất cả mọi người xem và lưu, không chỉnh sửa","removeResourceQuestion":"Bạn có chắc chắn muốn xóa hình ảnh này không?","removeResourceTitle":"Xóa hình ảnh khỏi bộ sưu tập","saveCollection":"Lưu bộ sưu tập","shareLink":"Chia sẻ liên kết đến bộ sưu tập:","sharePrivateOption":"\u003c1\u003e Riêng tư. \u003c/1\u003e Chỉ bạn mới có thể xem bộ sưu tập này","sharePublicOption":"\u003c1\u003e Công khai. \u003c/1\u003e Chia sẻ liên kết để cho phép truy cập","titleCollection":"Tiêu đề của bộ sưu tập","trendingCollections":"Bộ sưu tập thịnh hành giúp thúc đẩy ý tưởng của bạn","waitingAwesomeness":"Bộ sưu tập này vẫn đang chờ đợi một số điều tuyệt vời","wantToTry":"Bộ sưu tập cho phép bạn tự quản lý nội dung và sắp xếp các tài sản thuộc về nhau. Bạn có muốn thử không?"},"templatesCommon":{"FAQ":"Câu hỏi thường gặp","artboardA4":"A4","artboardA5":"A5","artboardBusinessCard":"Danh thiếp","artboardDesktopWallpaper":"Hình nền máy tính","artboardFacebookCover":"Ảnh bìa Facebook","artboardFacebookPost":"Bài đăng trên Facebook","artboardInstagramPost":"Bài đăng trên Instagram","artboardInstagramStories":"Câu chuyện Instagram","artboardXHeader":"Tiêu đề X","artboardYoutubeThumbnail":"Hình thu nhỏ của YouTube","categoryRow1":"Logo","categoryRow2":"Áp phích","categoryRow3":"Tờ rơi","categoryRow4":"Danh thiếp","categoryRow5":"Sơ yếu lý lịch","categoryRow6":"Biểu ngữ","chooseYourSettings":"Chọn cài đặt của bạn","createNewDesign":"Tạo thiết kế mới","faqsCategory1Content1":"Mẫu là một bố cục được thiết kế sẵn mà bạn có thể tùy chỉnh cho mục đích cá nhân hoặc chuyên nghiệp. Nó giúp bạn tiết kiệm thời gian và đảm bảo dự án của bạn trông bóng bẩy và nhất quán.","faqsCategory1Content2":"Chỉ cần chọn một mẫu bạn thích và khám phá các tùy chọn có sẵn. Một số mẫu có nút \u003cb\u003eChỉnh sửa trực tuyến\u003c/b\u003e cho phép bạn tùy chỉnh thiết kế ngay lập tức bằng \u003c1\u003eFreepik Designer\u003c/1\u003e. Những mẫu khác có thể được tải xuống và mở trong các công cụ thiết kế tương thích như Photoshop, Illustrator hoặc trình chỉnh sửa trực tuyến.","faqsCategory1Content3":"Nếu mẫu hỗ trợ chỉnh sửa trực tuyến, hãy nhấp vào \u003cb\u003eChỉnh sửa trực tuyến\u003c/b\u003e để mở trực tiếp trong \u003c1\u003eFreepik Designer\u003c/1\u003e và tùy chỉnh ngay lập tức—không cần phần mềm. Bạn cũng có thể tải xuống mẫu và mở trong các công cụ tương thích như Illustrator hoặc Photoshop. Chỉnh sửa văn bản, hình ảnh, màu sắc và bố cục bằng cách truy cập các lớp hoặc nhóm của tệp. Để có kết quả tốt nhất, hãy căn chỉnh nội dung của bạn một cách hợp lý, sử dụng màu sắc thương hiệu nhất quán và kiểm tra khoảng cách để có được sự cân bằng về mặt hình ảnh.","faqsCategory1Content4":"Có, rất nhiều mẫu trên Freepik được tải xuống miễn phí. Người dùng miễn phí có thể truy cập số lượng tải xuống giới hạn hằng ngày. Để có thêm nhiều tài nguyên và quyền truy cập không giới hạn, hãy nâng cấp lên \u003c1\u003ePremium\u003c/1\u003e.","faqsCategory1Content5":"Có, bạn có thể sử dụng các mẫu Freepik cho các dự án thương mại nếu bạn tuân thủ \u003c1\u003eđiều khoản bản quyền\u003c/1\u003e. Các mẫu miễn phí có thể yêu cầu tham chiếu tác giả, trong khi các mẫu Premium thì không.","faqsCategory1Content6":"Tùy thuộc vào công cụ chỉnh sửa, bạn có thể xuất bản thiết kế tùy chỉnh của mình ở các định dạng như JPG, PNG, PDF hoặc SVG—lý tưởng cho in ấn, web hoặc bản thuyết trình.","faqsCategory1Content7":"Freepik cho phép tải xuống miễn phí có giới hạn mỗi ngày. Sau khi tải xuống, bạn có thể chỉnh sửa bất kỳ mẫu nào bao nhiêu lần tùy thích. Chỉnh sửa trực tuyến thông qua \u003c1\u003eFreepik Designer\u003c/1\u003e có thể khả dụng cho một số mẫu nhất định, ngay cả đối với người dùng miễn phí.","faqsCategory1Content8":"Có. Các mẫu được cung cấp ở các định dạng như PSD, AI, EPS hoặc các định dạng có thể chỉnh sửa cho\u003c1\u003eFreepik Designer\u003c/1\u003e và các trình chỉnh sửa trực tuyến khác, giúp chúng tương thích với các công cụ thiết kế phổ biến như Photoshop, Illustrator và các nền tảng trên trình duyệt.","faqsCategory1Title1":"Mẫu là gì?","faqsCategory1Title2":"Làm cách nào để sử dụng các mẫu Freepik?","faqsCategory1Title3":"Làm cách nào để chỉnh sửa một mẫu từ Freepik?","faqsCategory1Title4":"Tôi có thể tải xuống các template Freepik miễn phí không?","faqsCategory1Title5":"Tôi có thể sử dụng các mẫu Freepik cho mục đích thương mại không?","faqsCategory1Title6":"Tôi có thể xuất các bản thiết kế ở định dạng nào?","faqsCategory1Title7":"Tôi có thể chỉnh sửa miễn phí bao nhiêu mẫu?","faqsCategory1Title8":"Có thể sử dụng các mẫu Freepik với phần mềm thiết kế khác không?","headingSection":"Mẫu thiết kế sẵn sàng sử dụng","height":"Chiều cao","makersToGoSectionName":"Dành cho nhà sáng tạo","makersToGoSubtitle":"Hãy xem những ý tưởng mạnh mẽ của bạn trở nên sống động với các công cụ trực tuyến của chúng tôi. Cho dù là cho bất kỳ dự án cá nhân nào hay để thúc đẩy doanh nghiệp của bạn, tại đây bạn sẽ tìm thấy trình tạo lý tưởng để tạo ra những thiết kế tuyệt vời một cách dễ dàng","makersToGoTitle":"Nhà sáng tạo hàng đầu cho sự sáng tạo vô tận","millimeters":"Milimet","newDesign":"Thiết kế mới","orSelectAFormat":"Hoặc chọn một định dạng","pixels":"Điểm ảnh","relatedArticlesTitle":"Bài viết liên quan","searchingForPsdButton":"Xem ở đây này!","searchingForPsdTitle":"Bạn đang tìm kiếm các template PSD?","sizeError":"Độ phân giải không được lớn hơn 23622 x 23622 px hoặc nhỏ hơn 90 x 90 px","sizeErrorMm":"Đặt kích thước bản vẽ giữa 24 mm và 6250 mm","width":"Chiều rộng"},"templatesHome":{"aiWriterTool":"Trình tạo văn bản AI","aiWriterToolDescription":"Tạo nội dung nhanh chóng, dễ dàng và miễn phí, đồng thời tạm biệt tình trạng bí ý tưởng viết lách","artboardCustomSize":"Kích thước tùy chỉnh","artboardsSectionName":"Bắt đầu bằng cách chọn định dạng mẫu","artboardsSubtitle":"Bạn muốn bắt đầu lại từ đầu? Các định dạng được xác định trước sẽ giúp bạn thiết kế theo nhu cầu cụ thể và thỏa sức sáng tạo","artboardsTitle":"Mẫu trống để chỉnh sửa mọi lúc mọi nơi","backgroundRemoverTool":"Trình xóa nền","backgroundRemoverToolDescription":"Tách biệt mọi đối tượng trong ảnh mà không làm giảm chất lượng","bannerTemplates":"Mẫu banner","bookCoverTemplates":"Mẫu bìa sách","bookletTemplates":"Mẫu tập sách","bookmarkTemplates":"Mẫu đánh dấu","brochureTemplates":"Mẫu Tờ rơi","browseEditablePSDs":"Duyệt PSD có thể chỉnh sửa","businessCardTemplates":"Mẫu Danh thiếp","businessPlanTemplates":"Mẫu kế hoạch kinh doanh","calendarTemplates":"Mẫu Lịch","cardTemplates":"Mẫu Thiệp","cdCoverTemplates":"Mẫu bìa đĩa CD","certificateTemplates":"Mẫu chứng chỉ","checklistTemplates":"Mẫu danh mục kiểm tra","christmasCardTemplates":"Mẫu thiệp Giáng sinh","christmasFlyerTemplates":"Mẫu tờ rơi Giáng sinh","christmasGiftTagTemplates":"Mẫu thẻ quà tặng Giáng sinh","christmasInvitationTemplates":"Mẫu lời mời Giáng sinh","christmasLetterTemplates":"Mẫu thư Giáng sinh","christmasListTemplates":"Mẫu danh sách Giáng sinh","christmasLunchInvitationTemplates":"Mẫu lời mời ăn trưa Giáng sinh","christmasOrnamentTemplates":"Mẫu đồ trang trí Giáng sinh","christmasPartyInvitationTemplates":"Mẫu lời mời dự tiệc Giáng sinh","christmasPosterTemplates":"Mẫu poster Giáng sinh","christmasTemplates":"Mẫu Giáng sinh","christmasWishListTemplates":"Mẫu danh sách mong muốn Giáng sinh","collageTemplates":"Mẫu ảnh ghép","couponTemplates":"Mẫu phiếu giảm giá","coverLetterTemplates":"Mẫu Đơn Xin Việc","coverSubtitle":"Khám phá các mẫu có thể chỉnh sửa và nhận các thiết kế chuyên nghiệp cho thương hiệu, doanh nghiệp hoặc mạng xã hội của bạn. Chỉnh sửa trực tuyến chỉ với một vài cú nhấp chuột—không cần phần mềm.","coverTitle":"Mẫu miễn phí để chỉnh sửa trực tuyến","diagramTemplates":"Mẫu sơ đồ","easterBunnyTemplates":"Mẫu thỏ Phục sinh","easterTemplates":"Mẫu lễ Phục sinh","facebookAdTemplates":"Mẫu quảng cáo Facebook","facebookCoverTemplates":"Mẫu Ảnh bìa Facebook","facebookPostTemplates":"Mẫu bài đăng Facebook","flyerTemplates":"Mẫu tờ rơi","ghostTemplates":"Mẫu Ghost","giftCertificateTemplates":"Mẫu Giấy Chứng Nhận Quà Tặng","giftTagTemplates":"Mẫu Thẻ Quà Tặng","gridSectionName":"Mẫu","gridSubtitle":"Bắt đầu thiết kế đồ họa dễ dàng ngay tại đây! Khám phá các mẫu tùy chỉnh cho một thương hiệu vững chắc, hoạt động marketing hiệu quả, các chiến dịch truyền thông xã hội thông minh và nhiều hơn thế nữa","gridTitle":"Các mẫu có thể chỉnh sửa cho mọi dự án","halloweenInvitationTemplates":"Mẫu thiệp mời Halloween","halloweenPosterTemplates":"Mẫu áp phích Halloween","halloweenPumpkinFaceTemplates":"Mẫu mặt bí ngô Halloween","halloweenTemplates":"Mẫu Halloween","holiTemplates":"Mẫu Holi","idCardsTemplates":"Mẫu thẻ căn cước","infographicTemplates":"Mẫu Biểu đồ thông tin","instagramPostTemplates":"Mẫu Bài Đăng Instagram","instagramStoryTemplates":"Mẫu Story Instagram","invitationTemplates":"Mẫu lời mời","invoiceTemplates":"Mẫu hóa đơn","labelTemplates":"Mẫu Nhãn","lessonPlanTemplates":"Mẫu kế hoạch bài học","letterheadsTemplate":"Mẫu Giấy Tiêu Đề","listTemplates":"Mẫu Danh Sách","logIn":"Đăng nhập","loginModal":{"body":"Chúng tôi đã chuyển các tính năng của Wepik sang Freepik, cung cấp cho bạn nhiều tài nguyên thiết kế hơn và sự linh hoạt sáng tạo. Các dự án của bạn vẫn ở đây—an toàn, lành mạnh và sẵn sàng cho bạn trong phần Dự án!","subtitle":"Tất cả tính năng yêu thích của bạn giờ đây đều có ở cùng một nơi.","title":"Wepik hiện là một phần của Freepik!"},"logoTemplates":"Mẫu Logo","magazineCoversTemplates":"Mẫu bìa tạp chí","memeTemplates":"Mẫu Meme","menuTemplates":"Mẫu Menu","microfunnelFreeCTA":"Bắt đầu ngay","microfunnelFreeSubtitle":"Chọn một mẫu, tùy chỉnh trực tuyến và biến nó thành của bạn","microfunnelFreeTitle":"Không cần phần mềm \u003c1 /\u003eChỉ cần một mẫu để bắt đầu","moneyTemplates":"Mẫu tiền","moodBoardTemplates":"Mẫu bảng tâm trạng","mothersDayCardTemplates":"Mẫu thiệp Ngày của Mẹ","nameTagsTemplates":"Thẻ tên Mẫu","newTools":{"buttonText":"Khám phá tất cả các công cụ","cards":{"aiAssitant":"Trợ Lý AI","generateAMockups":"Tạo một mô hình","generateAnImage":"Tạo hình ảnh","socialMediaPosts":"Tạo bài đăng trên mạng xã hội"},"find":"Tìm","title":"Tạo ra những thiết kế độc đáo bằng nội dung AI của riêng bạn","tryIt":"Dùng thử"},"newYearBannerTemplates":"Mẫu biểu ngữ năm mới","newYearFlyerTemplates":"Mẫu tờ rơi năm mới","newYearPosterTemplates":"Mẫu poster năm mới","newsletterTemplates":"Mẫu bản tin","onePagerTemplate":"Mẫu một trang","plannerTemplates":"Mẫu Lịch","popularSearchItem1":"Biểu trưng","popularSearchItem2":"Danh thiếp","popularSearchItem3":"Tờ rơi","postcardTemplate":"Mẫu bưu thiếp","posterTemplatesTemplates":"Mẫu Poster","priceListTemplates":"Mẫu Bảng Giá","profilePictureTemplate":"Mẫu Ảnh Hồ Sơ","proposalTemplates":"Mẫu Đề Xuất","pumpkinTemplates":"Mẫu bí ngô","ramadanTemplates":"Mẫu Ramadan","recommendationLetterTemplates":"Mẫu Thư Giới Thiệu","resignationLetterTemplates":"Mẫu đơn xin từ chức","resumeTemplates":"Mẫu sơ yếu lý lịch","saintPatricksDayTemplates":"Mẫu Ngày Thánh Patrick","santaLetterTemplates":"Mẫu thư của ông già Noel","scheduleTemplates":"Mẫu lịch trình","seoDescription":"Khám phá các mẫu có thể chỉnh sửa miễn phí để tạo ra các thiết kế tùy chỉnh trực tuyến—lý tưởng cho việc xây dựng thương hiệu, kinh doanh hoặc mạng xã hội. Chỉnh sửa chỉ với vài cú nhấp chuột và tải xuống dễ dàng!","seoTitle":"Mẫu miễn phí để chỉnh sửa trực tuyến | Freepik","shoppingListTemplates":"Mẫu danh sách mua sắm","shortcuts":{"aiAssistant":"Trợ Lý AI","designer":"Designer","mockupGenerator":"Trình tạo mô hình"},"signTemplates":"Mẫu Biển Báo","signUp":"Đăng ký","snowflakeTemplates":"Mẫu bông tuyết","snowmanTemplates":"Mẫu người tuyết","springTemplates":"Mẫu mùa xuân","stickerTemplates":"Mẫu hình dán","storyboardTemplates":"Mẫu kịch bản phân cảnh","tabBannersCovers":"Banner \u0026 ảnh bìa","tabBranding":"Xây dựng thương hiệu","tabBusiness":"Doanh nghiệp","tabFestivities":"Lễ hội","tabMarketing":"Tiếp thị","tabPersonal":"Cá nhân","tabSocialMedia":"Mạng Xã Hội","tabStationery":"Ấn phẩm văn phòng","tableOfContentsTemplate":"Mục lục Mẫu","teachersDayCardTemplates":"Mẫu thiệp mừng Ngày Nhà giáo","textToImageTool":"Văn bản thành hình ảnh","textToImageToolDescription":"Biến lời nói của bạn thành những hình ảnh đáng kinh ngạc với Trình tạo ảnh AI Freepik","thanksgivingBannerTemplates":"Mẫu biểu ngữ Lễ Tạ ơn","thanksgivingInvitationTemplates":"Mẫu lời mời Lễ Tạ ơn","thanksgivingMenuTemplates":"Mẫu thực đơn Lễ Tạ ơn","thanksgivingTemplates":"Mẫu Lễ Tạ ơn","ticketTemplates":"Mẫu vé","timelineTemplates":"Mẫu Dòng Thời Gian","tools":{"buttonText":"Khám phá tất cả các công cụ","cards":{"generateAVoiceover":"Tạo thuyết minh","generateAnAiVideo":"Tạo một video AI","upscaleVideo":"Nâng cấp video","videoEditor":"Trình Sửa Video"},"find":"Tìm","title":"Tạo ra những thiết kế độc đáo bằng nội dung AI của riêng bạn","tryIt":"Dùng thử"},"toolsSectionName":"Cô